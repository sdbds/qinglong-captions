{
  "name": "FLUX.2 Dev LoRA",
  "description": "FLUX.2 Dev 模型的 LoRA 训练预设（推理用，不建议训练）",
  "arch": "FLUX.2",
  "version": "dev",
  "output_name": "flux2_dev_lora",
  "seed": 1026,
  "max_train_epochs": 10,
  "max_train_steps": 0,
  "batch_size": 1,
  "gradient_accumulation_steps": 1,
  "mixed_precision": "bf16",
  "timestep_sampling": "flux2_shift",
  "weighting_scheme": "none",
  "guidance_scale": 1.0,
  "discrete_flow_shift": 3.0,
  "network_dim": 16,
  "network_alpha": 8,
  "network_dropout": 0.0,
  "gradient_checkpointing": true,
  "gradient_checkpointing_cpu_offload": false,
  "fp8_base": false,
  "fp8_scaled": false,
  "fp8_text_encoder": false,
  "blocks_to_swap": 10,
  "split_attn": true,
  "optimizer_type": "AdamW_adv",
  "learning_rate": "5e-5",
  "lr_scheduler": "cosine_with_min_lr",
  "lr_warmup_steps": 0,
  "lr_scheduler_min_lr_ratio": 0.1,
  "max_grad_norm": 1.0,
  "scale_weight_norms": 0,
  "save_every_n_epochs": 2,
  "save_every_n_steps": 0,
  "max_data_loader_n_workers": 8,
  "persistent_data_loader_workers": true,
  "attn_mode": "flash",
  "vae_dtype": "float32"
}
